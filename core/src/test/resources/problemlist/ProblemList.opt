                                        <rm_type_name>CLUSTER</rm_type_name>
                                        <occurrences>
                                            <lower_included>true</lower_included>
                                            <upper_included>false</upper_included>
                                            <lower_unbounded>false</lower_unbounded>
                                            <upper_unbounded>true</upper_unbounded>
                                            <lower>0</lower>
                                        </occurrences>
                                        <node_id>at0054</node_id>
                                        <includes>
                                            <string_expression>archetype_id/value matches {/openEHR-EHR-CLUSTER\.media_file\.v1/}</string_expression>
                                            <expression xsi:type="EXPR_BINARY_OPERATOR">
                                                <type>Boolean</type>
                                                <operator>2007</operator>
                                                <precedence_overridden>false</precedence_overridden>
                                                <left_operand xsi:type="EXPR_LEAF">
                                                    <type>String</type>
                                                    <item xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema">archetype_id/value</item>
                                                    <reference_type>attribute</reference_type>
                                                </left_operand>
                                                <right_operand xsi:type="EXPR_LEAF">
                                                    <type>String</type>
                                                    <item xsi:type="C_STRING">
                                                        <pattern>openEHR-EHR-CLUSTER\.media_file\.v1</pattern>
