                                <term_definitions code="at0000">
                                    <items id="text">Organisationseinheit</items>
                                    <items id="description">Eine fachliche Einheit, Organisation, Abteilung, Zusammenschluss, Gruppierung mit einem gemeinsamen Ziel.</items>
                                </term_definitions>
                                <term_definitions code="at0024">
                                    <items id="text">Organisationsschlüssel</items>
                                    <items id="description">Eindeutiger Identifikator der Organisationseinheit.</items>
                                </term_definitions>
                                <term_definitions code="at0046">
                                    <items id="text">Zusätzliche Beschreibung</items>
                                    <items id="description">Zusätzliche Informationen</items>
                                </term_definitions>
                                <term_definitions code="at0047">
                                    <items id="text">Details</items>
                                    <items id="description">Für die Erfassung weiterer Angaben über die Organisationseinheit, zum Beispiel Adresse oder Telekommunikationsdetails.</items>
                                </term_definitions>
                                <term_definitions code="at0050">
                                    <items id="text">Aktiv/Inaktiv</items>
                                    <items id="description">Gibt an, ob die Organisationseinheit noch aktiv ist.</items>
                                </term_definitions>
                                <term_definitions code="at0051">
                                    <items id="text">Typ</items>
                                    <items id="description">Art der Organisationseinheit.</items>
                                    <items id="comment">Zum Beispiel: Fachabteilung im Krankenhaus, Versicherungsunternehmen, Sponsor</items>
                                </term_definitions>
                                <term_definitions code="at0052">
                                    <items id="text">Name</items>
                                    <items id="description">Bezeichnung für die Organisationseinheit</items>
                                </term_definitions>
                            </children>
