                                    <value>openEHR-EHR-CLUSTER.organisation.v1</value>
                                </archetype_id>
                                <term_definitions code="at0000">
                                    <items id="text">Überweiser</items>
                                    <items id="description">Eine Einheit, die aus einer oder mehreren Personen besteht und ein bestimmtes Ziel hat.</items>
                                    <items id="comment">Zum Beispiel: ein Unternehmen, eine Institution, ein Verband, ein Netzwerk, eine Abteilung, eine Gemeindegruppe, eine Gesundheitspraxisgruppe, ein Kostenträger/Versicherer, ein Pflegeteam oder eine Gruppe von Nachbarn, die Pflege oder Unterstützung leisten.</items>
                                </term_definitions>
                                <term_definitions code="at0001">
                                    <items id="text">Namenszeile</items>
                                    <items id="description">Der Name oder Bezeichnung der Organisation in unstrukturierter Form.</items>
                                    <items id="comment">Zum Beispiel: „Royal Children's Hospital“, "ABC-Krankenpflegedienst", „YNWA Oslo“ oder „JB Smith Rechtsanwälte“.</items>
                                </term_definitions>
                                <term_definitions code="at0002">
                                    <items id="text">Kontaktperson</items>
                                    <items id="description">Details zu einer oder mehreren Personen innerhalb der Organisation.</items>
                                </term_definitions>
                                <term_definitions code="at0003">
                                    <items id="text">Identifier</items>
                                    <items id="description">Identifikator, der der identifizierten Organisation zugeordnet ist.</items>
                                    <items id="comment">Kardinalität für dieses Datenelement wird auf 0..* gesetzt, damit mehr als ein Identifikator aufgezeichnet werden kann. Beachten Sie, dass der ID-Datentyp mehrere Unterkomponenten zum Aufzeichnen des ID-Werts, -Typs, -Ausstellers und -Zuweisers enthält.</items>
                                </term_definitions>
                                <term_definitions code="at0004">
                                    <items id="text">Funktion</items>
                                    <items id="description">Die Beziehung oder Rolle der Organisation zum Pflegebedürftigen oder Patient.</items>
                                    <items id="comment">Zum Beispiel: Onkologe, ambulanter Palliativdienst oder informelles Supportnetzwerk.</items>
                                </term_definitions>
                                <term_definitions code="at0005">
                                    <items id="text">Adresse</items>
                                    <items id="description">Angaben zu einer Adresse der Organisation.</items>
                                </term_definitions>
                                <term_definitions code="at0017">
                                    <items id="text">Zusätzliche Details</items>
                                    <items id="description">Weitere Angaben zur Organisation.</items>
                                </term_definitions>
                                <term_definitions code="at0019">
                                    <items id="text">Kommentar</items>
                                    <items id="description">Zusätzlicher Text zu der Organisation, der in anderen Bereichen nicht erfasst wird.</items>
                                </term_definitions>
                                <term_definitions code="at0021">
                                    <items id="text">Muttergesellschaft</items>
                                    <items id="description">Eine größere Organisation, von der diese Organisation ein Sub- oder Tochterunternehmen ist.</items>
                                </term_definitions>
                                <term_definitions code="at0022">
                                    <items id="text">Elektronische Kommunikation</items>
                                    <items id="description">Details zu einer oder mehreren Arten der elektronischen Kommunikation für die Organisation.</items>
