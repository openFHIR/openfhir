                                <archetype_id>
                                    <value>openEHR-EHR-CLUSTER.location.v1</value>
                                </archetype_id>
                                <term_definitions code="at0024">
                                    <items id="text">Campus</items>
                                    <items id="description">Eine Gruppe von Gebäuden an anderen Orten, wie ein örtlich entfernter Campus, der außerhalb der Einrichtung liegt, aber zur Institution gehört.</items>
                                </term_definitions>
                                <term_definitions code="at0025">
                                    <items id="text">Gebäudegruppe</items>
                                    <items id="description">Ein Gebäude oder Bauwerk. Dazu können Räume, Flure, Flügel, etc. gehören. Es hat möglicherweise keine Wände oder ein Dach, wird aber dennoch als definierter/zugeordneter Raum angesehen.</items>
                                </term_definitions>
                                <term_definitions code="at0027">
                                    <items id="text">Station</items>
                                    <items id="description">Eine Station ist Teil einer medizinischen Einrichtung, die Räume und andere Arten von Orten enthalten kann.</items>
                                </term_definitions>
                                <term_definitions code="at0028">
                                    <items id="text">Ebene</items>
                                    <items id="description">Die Ebene in einem mehrstöckigen Gebäude/Bauwerk.</items>
                                </term_definitions>
                                <term_definitions code="at0029">
                                    <items id="text">Zimmer</items>
                                    <items id="description">Ein Ort, der als Zimmer deklariert wurde. Bei einigen Standorten kann das Zimmer im Flur liegen zB: Station XYZ Flur 2. Hierbei liegt der Bettstellplatz 2 auf dem Flur der jeweiligen Station. </items>
                                </term_definitions>
                                <term_definitions code="at0034">
                                    <items id="text">Bettstellplatz</items>
                                    <items id="description">Beschreibung des Bettstellplatzes z.B. Bett stand neben dem Fenster oder neben der Tür.</items>
                                </term_definitions>
                                <term_definitions code="at0046">
                                    <items id="text">Status</items>
                                    <items id="description">Das Feld enthält die Freitextbeschreibung des Standorts, z.B. Throax-, Herz- und Gefäßchirurgie.</items>
                                </term_definitions>
                                <term_definitions code="at0047">
                                    <items id="text">Details</items>
                                    <items id="description">Für die Erfassung weiterer Angaben über das Bett oder der Adresse. Verwenden Sie dazu den Archetyp CLUSTER.device oder CLUSTER.address.</items>
                                </term_definitions>
                                <term_definitions code="at0049">
                                    <items id="text">Leitende Organisationseinheit</items>
                                    <items id="description">Organisation, die für die Bereitstellung und Instandhaltung verantwortlich ist&#13;
&#13;
Die Organisation, die für die Bereitstellung und den Unterhalt des Standorts verantwortlich ist.&#13;
</items>
                                </term_definitions>
                                <term_definitions code="at0000">
                                    <items id="text">Standort</items>
                                    <items id="description">Standort umfasst sowohl beiläufige Orte (ein Ort, der für die medizinische Versorgung ohne vorherige Benennung oder Genehmigung genutzt wird) als auch spezielle, offiziell benannte Orte. Die Standorte können privat, öffentlich, mobil oder stationär sein.</items>
                                </term_definitions>
                            </children>
                            <cardinality>
                                <is_ordered>false</is_ordered>
                                <is_unique>false</is_unique>
                                <interval>
                                    <lower_included>true</lower_included>
                                    <upper_included>false</upper_included>
                                    <lower_unbounded>false</lower_unbounded>
                                    <upper_unbounded>true</upper_unbounded>
                                    <lower>0</lower>
                                </interval>
                            </cardinality>
                        </attributes>
                    </children>
                </attributes>
                <archetype_id>
                    <value>openEHR-EHR-ADMIN_ENTRY.episode_institution_local.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Institutionsaufenthalt</items>
                    <items id="description">Zur Erfassung administrativer Details über den Zeitraum einer Patientenversorgung, zwischen einer formellen oder statistischen Aufnahme und einer formellen oder statistischen Entlassung, welche nur durch eine Versorgungsform der Gesundheitseinrichtung charakterisiert ist.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Entlassungsdatum</items>
                    <items id="description">Das Datum und/oder die Uhrzeit der formellen oder statistischen institutionellen Entlassung.</items>
                    <items id="comment">Beispiel: Überführung in häusliche Pflege oder eine andere Institution, Todeszeitpunkt.&#13;
Für die Dokumentation des Todeszeitpunkts sollte CLUSTER.death_details genutzt werden.</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Kategorie des Zielortes der Entlassung</items>
                    <items id="description">Die Art der Unterkunft, in welche die Person entlassen wurde.</items>
                    <items id="comment">Zum Beispiel: nach Hause, Krankenhaus, Pflegeheim, Rehabilitierungszentrum.</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Aufnahmedatum</items>
                    <items id="description">Das Datum und/oder Uhrzeit der formellen oder statistischen institutionellen Aufnahme.</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">EntlassungsgrundErsteUndZweiteStelle</items>
                    <items id="description">Outcome des Aufenthaltes zum Zeitpunkt der Entlassung.</items>
                    <items id="comment">Zum Beispiel: genesen/nicht genesen/tot</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Zuweiserkategorie</items>
                    <items id="description">Der Typ der zuweisenden Einheit vor der Aufnahme.</items>
                    <items id="comment">Zum Beispiel: Krankenhaus, gemeinschaftliche Wohneinrichtung, Pflegeheim. Wenn möglich sollte die Zuweiserkategorie mittels einer Terminologie kodiert werden.</items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">Aufnahmegrund - Vierte Stelle</items>
                    <items id="description">Der Anlass, aus dem die Person zur Versorgung aufgenommen wurde.</items>
                    <items id="comment">Zum Beispiel: Kurzzeitpflege, Rehabilitation, Isolierung aufgrund einer Infektion.&#13;
Bei Bedarf sollten Diagnosen per EVAL.problem_diagnosis und dem verschachteltem CLUSTER.problem_qualifier Archetyp dokumentiert werden.</items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Aufnahmekategorie</items>
                    <items id="description">Die Art der Aufnahme.</items>
                    <items id="comment">Zum Beispiel: ambulante Operation, elektive Operation oder Notfall</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Kommentar</items>
                    <items id="description">Weitere Informationen zum Aufenthalt, soweit noch nicht in anderen Feldern erfasst.</items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">Zusätzliche Details</items>
                    <items id="description">Zusätzliche strukturierte Details über den Aufenthalt in der Institution.</items>
                    <items id="comment">Zum Beispiel:</items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">Zielort der Entlassung</items>
                    <items id="description">Die Organisation oder Adresse, an welche die Person entlassen wurde.</items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Zuweiser</items>
                    <items id="description">Die Organisation oder Adresse der Person vor der Aufnahme.</items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Versorgungsfall ID</items>
                    <items id="description">Eine Kennung zur Identifizierung des Versorgungsfalles.</items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">Behandelnde Mediziner</items>
                    <items id="description">Angaben zu den Beratenden und zu den behandelnden Mediziner*innen während des Aufenthaltes.</items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Nummer der Krankenakte</items>
                    <items id="description">Identifizierende Nummer der Krankenakte.</items>
                </term_definitions>
                <term_definitions code="at0021">
                    <items id="text">Behandelnde Organisationseinheit</items>
                    <items id="description">Die für die Behandlung verantwortliche Organisationseinheit.</items>
                    <items id="comment">Zum Beispiel: Orthopädie</items>
                </term_definitions>
                <term_definitions code="at0026">
                    <items id="text">Krankenversicherungskategorie</items>
                    <items id="description">Anzuwendender Krankenversicherungstyp für diesen Aufenthalt.</items>
                </term_definitions>
                <term_definitions code="at0027">
                    <items id="text">Überweisender Mediziner</items>
                    <items id="description">Details zu den Mediziner*innen, die für die Überweisung der Person aus dem Zuweiser verantwortlich sind.</items>
                </term_definitions>
                <term_definitions code="at0032">
                    <items id="text">Standort</items>
                    <items id="description"></items>
                </term_definitions>
            </children>
