                <archetype_id>
                    <value>openEHR-EHR-ACTION.procedure.v1</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Prozedur</items>
                    <items id="description">Eine klinische Aktivität, die zur Früherkennung, Untersuchung, Diagnose, Heilung, Therapie, Bewertung oder in Hinsicht auf palliative Maßnahmen durchgeführt wird.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Name der Prozedur</items>
                    <items id="description">Identifizierung der Prozedur über den Namen.</items>
                    <items id="comment">Wenn möglich wird die Kodierung der spezifischen Prozedur mit einer Terminologie bevorzugt.</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Details zur Prozedur</items>
                    <items id="description">Strukturierte Informationen über die Prozedur.</items>
                    <items id="comment">Zur Erfassung detaillierter, strukturierter Informationen über die anatomische Lokalisation, Methode und Technik, verwendetes Equipment, implantierte Geräte, Ergebnisse, Befunde usw.</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Geplante Prozedur</items>
                    <items id="description">Die Prozedur, die durchgeführt werden soll, ist geplant.</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Kommentar</items>
                    <items id="description">Zusätzliche Beschreibung der Aktivität oder der "Pathway"-Verlaufsschritte, die in anderen Bereichen nicht erfasst wurden.</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Komplikationen</items>
                    <items id="description">Details zu allen Komplikationen, die sich aus der Prozedur ergeben haben.</items>
                    <items id="comment">Verwenden Sie dieses Datenelement, um einfache Begriffe oder präkoordinierte Komplikationen zu erfassen. Wenn die Anforderungen an die Erfassung der Komplikationen komplexer sind, wird die Verwendung eines spezifischen CLUSTER-Archetyps innerhalb des Slots "Details zur Prozedur" in diesem Archetyp empfohlen. Dieses Datenelement wird dann redundant. Beispiele: Hämaturie nach einer Nierenbiopsie, Reizungen des Gewebes nach dem Legen eines intravenösen Katheters.</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Auftrag für Prozedur versendet</items>
                    <items id="description">Der Auftrag für die Prozedur wurde versendet.</items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Durchführungsabsicht</items>
                    <items id="description">Grund, warum die angegebene Aktivität für diese Prozedur durchgeführt wurde.</items>
                    <items id="comment">Zum Beispiel: der Grund für den Abbruch oder die Unterbrechung der Prozedur.</items>
                </term_definitions>
                <term_definitions code="at0034">
                    <items id="text">X - Prozedur geplant</items>
                    <items id="description">Dieses Element ist veraltet, da es fälschlicherweise mit dem Status "initial" verknüpft war - verwenden Sie das neue Element "Prozedur geplant" (at0004), das korrekt mit dem Status "geplant" verknüpft ist.</items>
                    <items id="comment">(War: Die Prozedur, die durchgeführt werden soll, ist geplant.)</items>
                </term_definitions>
                <term_definitions code="at0035">
                    <items id="text">X - Auftrag für Prozedur versendet</items>
                    <items id="description">Dieses Element ist veraltet, da es fälschlicherweise mit dem Status "initial" verknüpft war - verwenden Sie das neue Element "Geplante Prozedur" (at0007), das korrekt mit dem Status "geplant" verknüpft ist.</items>
                    <items id="comment">(War: Der Auftrag für die Prozedur wurde versendet.)</items>
                </term_definitions>
                <term_definitions code="at0036">
                    <items id="text">geplanter Termin der Prozedur</items>
                    <items id="description">Ein Termin für die Prozedur wurde geplant.</items>
                </term_definitions>
                <term_definitions code="at0038">
                    <items id="text">Prozedur verschoben</items>
                    <items id="description">Die Prozedur wurde verschoben.</items>
                </term_definitions>
                <term_definitions code="at0039">
                    <items id="text">Prozedur storniert</items>
                    <items id="description">Die geplante Prozedur wurde vor Beginn storniert.</items>
                </term_definitions>
                <term_definitions code="at0040">
                    <items id="text">Prozedur unterbrochen</items>
                    <items id="description">Die Prozedur wurde unterbrochen.</items>
                </term_definitions>
                <term_definitions code="at0041">
                    <items id="text">Prozedur abgebrochen</items>
                    <items id="description">Die Prozedur wurde abgebrochen.</items>
                </term_definitions>
                <term_definitions code="at0043">
                    <items id="text">Prozedur beendet</items>
                    <items id="description">Die Prozedur wurde durchgeführt und alle damit verbundenen klinischen Aktivitäten wurden beendet.</items>
                </term_definitions>
                <term_definitions code="at0047">
                    <items id="text">Prozedur durchgeführt</items>
                    <items id="description">Die Prozedur, oder eine Subprozedur in einem mehrstufigen Vorgehen, wurde durchgeführt.</items>
                </term_definitions>
                <term_definitions code="at0048">
                    <items id="text">Lateralität</items>
                    <items id="description">Ausgang der durchgeführten Prozedur.</items>
                    <items id="comment">Wenn möglich wird die Kodierung mit einer Terminologie bevorzugt.</items>
                </term_definitions>
                <term_definitions code="at0049">
                    <items id="text">Freitextbeschreibung</items>
                    <items id="description">Beschreibung der Prozedur, angepasst an den "Pathway"-Verlaufsschritt.</items>
                    <items id="comment">Zum Beispiel: Beschreibung der Durchführung und der Ergebnisse dieser Prozedur, des abgebrochenen Versuchs oder der Stornierung der Prozedur.</items>
                </term_definitions>
                <term_definitions code="at0053">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0054">
                    <items id="text">Auftragskennung des Antragstellers</items>
                    <items id="description">Die lokale ID, die dem Auftrag vom Gesundheitsdienstleister oder der Organisation, die die Leistung anfordert, zugewiesen wurde.</items>
                    <items id="comment">Dies entspricht der "Placer Order Number" in den Spezifikationen von HL7 v2.</items>
                </term_definitions>
                <term_definitions code="at0055">
                    <items id="text">Antragsteller</items>
                    <items id="description">Angaben über den Gesundheitsdienstleister oder die Organisation, die die Leistung anfordert.</items>
                </term_definitions>
                <term_definitions code="at0056">
                    <items id="text">Auftragskennung des Empfängers</items>
                    <items id="description">Die ID, die dem Auftrag von dem Gesundheitsdienstleister oder der Organisation, die die Leistungsanforderung erhält, zugewiesen wurde. Dies wird auch als "Filler Order Identifier" bezeichnet.</items>
                    <items id="comment">Dies entspricht der "Filler Order Number" in den Spezifikationen von HL7 v2.</items>
                </term_definitions>
                <term_definitions code="at0057">
                    <items id="text">Empfänger</items>
                    <items id="description">Angaben über den Gesundheitsdienstleister oder die Organisation, die die Leistungsanforderung erhält.</items>
                </term_definitions>
                <term_definitions code="at0058">
                    <items id="text">Dringlichkeit</items>
                    <items id="description">Dringlichkeit der Prozedur.</items>
                    <items id="comment">Wenn möglich wird die Kodierung mit einer Terminologie bevorzugt.</items>
                </term_definitions>
                <term_definitions code="at0060">
                    <items id="text">Enddatum/-uhrzeit</items>
                    <items id="description">Das Datum und/oder die Uhrzeit, an dem die gesamte Prozedur, oder die letzte Komponente einer mehrstufigen Prozedur, beendet wurde.</items>
                    <items id="comment">Nur zur Verwendung in Verbindung mit dem Element "Prozedur durchgeführt" und in Situationen, in denen die Prozedur vor dem Abschluss mehrmals wiederholt wird oder die Prozedur sich aus mehreren Komponenten zusammensetzt. Dies kann mit dem RM-Zeitattribut des Elements "Prozedur beendet" übereinstimmen.</items>
                </term_definitions>
                <term_definitions code="at0061">
                    <items id="text">Gesamtdauer</items>
                    <items id="description">Die Gesamtdauer der Prozedur - diese kann sich aus der aktiven Phase und der Phase, in der die Prozedur unterbrochen wurde, ergeben.</items>
                    <items id="comment">Nur in Verbindung mit dem Element "Prozedur beendet" verwenden.</items>
                </term_definitions>
                <term_definitions code="at0062">
                    <items id="text">Multimedia</items>
                    <items id="description">Multimediale Darstellung der durchgeführten Prozedur.</items>
                </term_definitions>
                <term_definitions code="at0063">
                    <items id="text">Körperstelle</items>
                    <items id="description">Anatomische Lokalisation, an der die Prozedur durchgeführt wird.</items>
                    <items id="comment">Das Vorkommen dieses Datenelements ist nicht eingeschränkt. Dies ermöglicht die Darstellung von klinischen Situationen, in denen alle Eigenschaften, ausgenommen die anatomische Lokalisation, identisch sind, wie z.B. das Entfernen mehrerer Hautläsionen an verschiedenen Stellen. Verwenden Sie dieses Datenelement, um einfache Begriffe oder präkoordinierte anatomische Lokalisationen aufzunehmen. Wenn die Anforderungen an die Erfassung der anatomischen Lokalisation zur Laufzeit durch die Anwendung festgelegt werden oder komplexere Modellierungen wie z.B. die relative Lokalisation erforderlich sind, verwenden Sie entweder CLUSTER.anatomical_location oder CLUSTER.relative_location innerhalb des Slots "Details zur Prozedur" in diesem Archetyp. Wird die anatomische Lokalisation über vordefinierte Codes in den Namen der Prozedur aufgenommen, wird dieses Datenelement redundant.</items>
                </term_definitions>
                <term_definitions code="at0064">
                    <items id="text">Erweiterung</items>
                    <items id="description">Zusätzliche Informationen, die erforderlich sind, um lokale Inhalte zu erfassen oder mit anderen Referenzmodellen/Formalismen abzugleichen.</items>
                    <items id="comment">Zum Beispiel: Lokaler Informationsbedarf oder zusätzliche Metadaten zur Anpassung an FHIR- oder CIMI-Äquivalente.</items>
                </term_definitions>
                <term_definitions code="at0065">
                    <items id="text">Methode</items>
                    <items id="description">Identifizierung der spezifischen Prozedurmethode oder -technik.</items>
                    <items id="comment">Verwenden Sie dieses Datenelement, um einfache Begriffe oder eine Beschreibung zu erfassen. Wenn die Anforderungen an die Erfassung der Methode eine komplexere Modellierung erfordern, kann dies durch zusätzliche Archetypen innerhalb des SLOTs "Details zur Prozedur" in diesem Archetyp dargestellt werden. Wird die Methode über vordefinierte Codes in dem Element "Name der Prozedur" aufgenommen, wird dieses Datenelement redundant.</items>
                </term_definitions>
                <term_definitions code="at0066">
                    <items id="text">Geplantes Datum/Uhrzeit</items>
                    <items id="description">Das Datum und/oder die Uhrzeit für die die Prozedur angesetzt ist.</items>
                    <items id="comment">Nur für die Verwendung in Verbindung mit dem Element "geplanter Termin der Prozedur" .</items>
                </term_definitions>
                <term_definitions code="at0067">
                    <items id="text">Kategorie der Prozedur</items>
                    <items id="description">Die Art der Prozedur.</items>
                    <items id="comment">Dieses pragmatische Datenelement kann zur Unterstützung der Gliederung für die Benutzeroberfläche verwendet werden.</items>
                </term_definitions>
                <term_definitions code="at0068">
                    <items id="text">Prozedur begonnen</items>
                    <items id="description">Die Prozedur, oder eine Subprozedur in einem mehrstufigen Vorgehen, wurde begonnen.</items>
                </term_definitions>
                <term_definitions code="at0069">
                    <items id="text">Schwierigkeiten bei der Durchführung der Prozedur</items>
                    <items id="description">Schwierigkeiten oder Probleme, die während der Durchführung der Prozedur aufgetreten sind.</items>
                    <items id="comment">Beispiele: Der Patient war unruhig; unzureichende Entleerung des Magens vor der Gastroskopie; ein Tumor in den Gallengängen machte es unmöglich, den Bereich zu passieren.</items>
                </term_definitions>
                <term_definitions code="at0070">
                    <items id="text">Indikation</items>
                    <items id="description">Der klinische oder prozessbezogene Grund für die Prozedur.</items>
                    <items id="comment">Die Kodierung der Indikation mit einer Terminologie wird nach Möglichkeit bevorzugt. Dieses Datenelement ermöglicht mehrere Vorkommen. Zum Beispiel: "Fehlgeschlagenen Darmvorbereitung" oder "Darmkrebsvorsorge".</items>
                </term_definitions>
            </children>
            <cardinality>
                <is_ordered>false</is_ordered>
                <is_unique>false</is_unique>
                <interval>
                    <lower_included>true</lower_included>
                    <upper_included>false</upper_included>
                    <lower_unbounded>false</lower_unbounded>
                    <upper_unbounded>true</upper_unbounded>
                    <lower>1</lower>
                </interval>
            </cardinality>
        </attributes>
        <archetype_id>
            <value>openEHR-EHR-COMPOSITION.report.v1</value>
        </archetype_id>
        <template_id>
            <value>KDS_Prozedur</value>
        </template_id>
        <term_definitions code="at0000">
            <items id="text">KDS_Prozedur</items>
            <items id="description">Ein Dokument zur Übermittlung von Informationen an andere, meist als Antwort auf eine Anfrage.</items>
        </term_definitions>
        <term_definitions code="at0001">
            <items id="text">Tree</items>
            <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0002">
            <items id="text">Bericht ID</items>
            <items id="description">Identifizierungsmerkmal des Berichts.</items>
        </term_definitions>
        <term_definitions code="at0005">
            <items id="text">Status</items>
            <items id="description">Der Status des gesamten Berichts. Hinweis: Dies ist nicht der Status einer Berichtskomponente.</items>
        </term_definitions>
        <term_definitions code="at0006">
            <items id="text">Erweiterung</items>
            <items id="description">Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</items>
            <items id="comment">Zum Beispiel: lokaler Informationsbedarf oder zusätzliche Metadaten zur Anpassung an FHIR-Ressourcen oder CIMI-Modelle.</items>
        </term_definitions>
    </definition>
