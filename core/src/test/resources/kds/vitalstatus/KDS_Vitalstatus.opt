                                <term_definitions code="at0000">
                                    <items id="text">Fallidentifikation</items>
                                    <items id="description">Zur Erfassung von Details zur Identifikation eines Falls im Gesundheitswesen.</items>
                                </term_definitions>
                                <term_definitions code="at0001">
                                    <items id="text">Fall-Kennung</items>
                                    <items id="description">Der Bezeichner/die Kennung dieses Falls.</items>
                                </term_definitions>
                                <term_definitions code="at0002">
                                    <items id="text">Fall-Beginn</items>
                                    <items id="description">Das Datum, an dem der Fall begann/eröffnet wurde.</items>
                                </term_definitions>
                                <term_definitions code="at0003">
                                    <items id="text">Status</items>
                                    <items id="description">Der Status des Falls. &#13;
Der Status "abgeschlossen" bedeutet, dass dem Patienten die entsprechende Fallnummer zugeordnet wurde. &#13;
Der Status "abgebrochen" bedeutet, dass dem Patienten die entsprechende Fallnummer fälschlicherweise zugeordnet wurde.</items>
                                </term_definitions>
                                <term_definitions code="at0004">
                                    <items id="text">Abgeschlossen</items>
                                    <items id="description">Dem Patienten wurde die entsprechende Fallkennung zugeordnet.</items>
                                </term_definitions>
                                <term_definitions code="at0005">
                                    <items id="text">Abgebrochen</items>
                                    <items id="description">Dem Patienten wurde die entsprechende Fallkennung fälschlicherweise zugeordnet.</items>
                                </term_definitions>
                                <term_definitions code="at0006">
                                    <items id="text">identifizierter Fall</items>
                                    <items id="description">Bezeichnung oder kodierter Text zur Bezeichnung des Falls.</items>
                                </term_definitions>
