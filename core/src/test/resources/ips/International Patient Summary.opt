                        <term_definitions code="at0000">
                            <items id="text">Exclusion of pregnancy</items>
                            <items id="description">Statement to explicitly record that a pregnancy was not present.</items>
                        </term_definitions>
                        <term_definitions code="at0001">
                            <items id="text">History</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0002">
