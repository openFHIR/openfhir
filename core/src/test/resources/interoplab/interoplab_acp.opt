                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::61396006">
                    <items id="text">structuur van linker bovenbeen</items>
                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::8205005">
                    <items id="text">structuur van polsregio</items>
                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::9736006">
                    <items id="text">structuur van rechter pols</items>
                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::5951000">
                    <items id="text">structuur van linker pols</items>
                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::7569003">
                    <items id="text">structuur van digitus van hand, exclusief digitus I</items>
                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::344001">
                    <items id="text">structuur van regio van enkel</items>
                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::6685009">
                    <items id="text">structuur van rechter enkel</items>
                </term_definitions>
                <term_definitions code="MeetLocatieCodelijst::51636004">
