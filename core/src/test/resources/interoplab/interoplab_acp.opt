        <archetype_id>
            <value>openEHR-EHR-COMPOSITION.care_plan.v0</value>
        </archetype_id>
        <template_id>
            <value>Advanced Care Planning Demo</value>
        </template_id>
        <term_definitions code="at0000">
            <items id="text">Advanced Care Planning Demo</items>
            <items id="description">A persistent and managed list of any combination of archetypes that will support the accurate recording of a Care plan.</items>
        </term_definitions>
        <term_definitions code="at0001">
            <items id="text">Tree</items>
            <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0002">
            <items id="text">Extension</items>
            <items id="description">Additional information required to extend the model with local content or to align with other reference models or formalisms.</items>
            <items id="comment">For example: local information requirements; or additional metadata to align with FHIR.</items>
        </term_definitions>
    </definition>
    <ontology archetype_id="openEHR-EHR-COMPOSITION.care_plan.v0">
        <term_definitions language="nl">
            <items code="at0000">
                <items id="text">Advanced Care Planning Demo</items>
                <items id="description">Een persistente en beheerde lijst van elke combinatie van archetypen die de nauwkeurige vastlegging van een Zorgplan ondersteunt.</items>
            </items>
            <items code="at0001">
                <items id="text">Tree</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0002">
                <items id="text">Extensie</items>
                <items id="description">Extra informatie benodigd voor het uitbreiden van het model met lokale informatie of voor het in lijn brengen met andere referentiemodellen of formalismen.</items>
                <items id="comment">Bijvoorbeeld: lokale informatie eisen; of extra metadata om in lijn te brengen met FHIR.</items>
            </items>
        </term_definitions>
    </ontology>
    <component_ontologies archetype_id="openEHR-EHR-OBSERVATION.blood_pressure.v2">
        <term_definitions language="nl">
            <items code="mm[Hg]">
                <items id="text">*mm[Hg] (en)</items>
                <items id="description">*millimeters of mercury (en)</items>
            </items>
            <items code="at0000">
                <items id="text">Bloeddruk</items>
                <items id="description">De lokale meting van de arteriële bloeddruk, welke surrogaat is voor de arteriële druk in de systemische circulatie.</items>
                <items id="comment">Meest gebruikelijk is dat de term 'bloeddruk' refereert aan de meting van de bloeddruk van de arterie brachialis in de bovenarm.</items>
            </items>
            <items code="at0001">
                <items id="text">Geschiedenis</items>
                <items id="description">Gestructureerde geschiedenismap.</items>
            </items>
            <items code="at0003">
                <items id="text">*Bloeddruk</items>
                <items id="description">*@ internal @</items>
            </items>
            <items code="at0004">
                <items id="text">Systolisch</items>
                <items id="description">De hoogste (piek) systemische arteriële bloeddruk - gemeten in de systolische of samentrekkingsfase van de hartslag.</items>
            </items>
            <items code="at0005">
                <items id="text">Diastolisch</items>
                <items id="description">De laagste systemische arteriële bloeddruk - gemeten in de diastolische of ontspanningsfase van de hartslag.</items>
            </items>
            <items code="at0006">
                <items id="text">Elke gebeurtenis</items>
                <items id="description">Standaard, niet-gespecificeerd tijdstip of interval gebeurtenis die expliciet in een template of tijdens uitvoering kan worden gedefinieerd.</items>
            </items>
            <items code="at0007">
                <items id="text">*state structure</items>
                <items id="description">*@ internal @</items>
            </items>
            <items code="at0008">
                <items id="text">Houding</items>
                <items id="description">De houding van het individu op het moment van de meting.</items>
            </items>
            <items code="at0011">
                <items id="text">Structuur</items>
                <items id="description">Lijst structuur.</items>
            </items>
            <items code="at0013">
                <items id="text">Manchet grootte</items>
                <items id="description">De grootte van de manchet gebruikt bij de meting.</items>
                <items id="comment">Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Human blood pressure determination by sphygmomanometry. Circulation 1993;88;2460-2470.</items>
            </items>
            <items code="at0014">
                <items id="text">Lichaamslocatie van de meting</items>
                <items id="description">Lichaamslocatie waar de bloeddruk is gemeten.</items>
            </items>
            <items code="at0015">
                <items id="text">Volwassen dijbeen</items>
                <items id="description">Een manchet voor een volwassen dijbeen.</items>
            </items>
            <items code="at0016">
                <items id="text">Grote volwassene</items>
                <items id="description">Een manchet voor volwassenen met grotere armen.</items>
            </items>
            <items code="at0017">
                <items id="text">Volwassene</items>
                <items id="description">De standaard manchet voor een volwassene.</items>
            </items>
            <items code="at0025">
                <items id="text">Rechterarm</items>
                <items id="description">De rechterarm van de persoon.</items>
            </items>
            <items code="at0026">
                <items id="text">Linkerarm</items>
                <items id="description">De linkerarm van de persoon.</items>
            </items>
            <items code="at0027">
                <items id="text">Rechterdijbeen</items>
                <items id="description">Het rechterdijbeen van de persoon.</items>
            </items>
            <items code="at0028">
                <items id="text">Linkerdijbeen</items>
                <items id="description">De linkerdijbeen van de persoon.</items>
            </items>
            <items code="at0033">
                <items id="text">Opmerking</items>
                <items id="description">Aanvullend opmerkingen over de meting, niet vastgelegd in andere velden.</items>
            </items>
            <items code="at1000">
                <items id="text">Staand</items>
                <items id="description">Bloeddrukmeting bij staand individu.</items>
            </items>
            <items code="at1001">
                <items id="text">Zittend</items>
                <items id="description">Bloeddrukmeting bij zittend (b.v. op bed of in stoel) individu.</items>
            </items>
            <items code="at1002">
                <items id="text">Halfzittend</items>
                <items id="description">Halfzittend op het moment van de bloeddrukmeting.</items>
            </items>
            <items code="at1003">
                <items id="text">Liggend</items>
                <items id="description">Platliggend op het moment van de bloeddrukmeting.</items>
            </items>
            <items code="at1005">
                <items id="text">Kanteling</items>
                <items id="description">De craniaal-caudale kanteling van het oppervlak waarop het individu ligt op het moment van de meting.</items>
            </items>
            <items code="at1006">
                <items id="text">Gemiddelde arteriële druk</items>
                <items id="description">De gemiddelde bloeddruk gedurende één cyclus van samentrekken en ontspannen van het hart.</items>
            </items>
            <items code="at1007">
                <items id="text">Polsdruk</items>
                <items id="description">Het verschil tussen de systolische en diastolische bloeddruk.</items>
            </items>
            <items code="at1008">
                <items id="text">Kleine volwassene</items>
                <items id="description">Een manchet voor een kleine volwassene.</items>
            </items>
            <items code="at1009">
                <items id="text">Pediatrie/kinder</items>
                <items id="description">Een manchet voor een kind of volwassene met een dunne arm.</items>
            </items>
            <items code="at1010">
                <items id="text">Diastolisch eindpunt</items>
                <items id="description">Om te registreren welk Korotkoff geluid gebruikt is om de diastolische druk te meten door de auscultatieve methode.</items>
            </items>
            <items code="at1011">
                <items id="text">Fase IV</items>
                <items id="description">Het vierde Korotkoff geluid wordt gedefinieerd als een abrupte vermindering van geluid.</items>
            </items>
            <items code="at1012">
                <items id="text">Fase V</items>
                <items id="description">Het vijfde Korotkoff geluid is geïdentificeerd door afwezigheid van geluiden als de manchetdruk onder diastolische bloeddruk komt.</items>
            </items>
            <items code="at1014">
                <items id="text">Liggend met kanteling naar linkerzijde</items>
                <items id="description">Platliggend met enige laterale kanteling, meestal gekanteld naar de linkerzijde. Gebruikelijk benodigd in het laatste trimester van de zwangerschap om aortacavale compressie te verlichten.</items>
            </items>
            <items code="at1018">
                <items id="text">Zuigeling</items>
                <items id="description">Een manchet voor zuigelingen.</items>
            </items>
            <items code="at1019">
                <items id="text">Neonaat</items>
                <items id="description">Een manchet voor een neonaat, er van uitgaande dat de manchet de juiste maat is voor volgroeidheid en geboortegewicht van de neonaat.</items>
            </items>
            <items code="at1020">
                <items id="text">Rechterpols</items>
                <items id="description">De rechterpols van de persoon</items>
            </items>
            <items code="at1021">
                <items id="text">Linkerpols</items>
                <items id="description">De linkerpols van de persoon.</items>
            </items>
            <items code="at1025">
                <items id="text">Apparaat</items>
                <items id="description">Details over sphygmomanometerof ander apparaat om de bloeddruk te meten.</items>
            </items>
            <items code="at1026">
                <items id="text">Rechterenkel</items>
                <items id="description">De rechterenkel van de persoon</items>
            </items>
            <items code="at1030">
                <items id="text">Inspanning</items>
                <items id="description">Details over de lichamelijke inspanning die ondernomen wordt op het moment van de bloeddrukmeting.</items>
            </items>
            <items code="at1031">
                <items id="text">Linkerenkel</items>
                <items id="description">De linkerenkel van de persoon.</items>
            </items>
            <items code="at1032">
                <items id="text">Vinger</items>
                <items id="description">Een vinger van de persoon.</items>
            </items>
            <items code="at1035">
                <items id="text">Methodiek</items>
                <items id="description">De methode van de meting van de bloeddruk.</items>
            </items>
            <items code="at1036">
                <items id="text">Auscultatie</items>
                <items id="description">Uitwendige meting van de bloeddruk, met gebruikmaking van een stethoscoop en Korotkoff geluiden.</items>
            </items>
            <items code="at1037">
                <items id="text">Palpatie</items>
                <items id="description">Uitwendige meting van de bloeddruk, met gebruikmaking van palpatie (meestal de arterie brachialis of radialis).</items>
            </items>
            <items code="at1038">
                <items id="text">Gemiddelde arteriële druk formule</items>
                <items id="description">Formule om de MAP (mean arterial pressure=gemiddelde arteriële druk) te berekenen (als deze data opgeslagen wordt).</items>
            </items>
            <items code="at1039">
                <items id="text">Machinaal</items>
                <items id="description">Uitwendige meting van de bloeddruk, met gebruikmaking van een mechanische bloeddrukmeter.</items>
            </items>
            <items code="at1040">
                <items id="text">Invasief</items>
                <items id="description">Inwendige meting van de bloeddruk, inclusief penetratie van de huid en meting in het bloedvat.</items>
            </items>
            <items code="at1042">
                <items id="text">24 uur gemiddelde</items>
                <items id="description">Inschatting van de gemiddelde bloeddruk over een periode van 24 uur.</items>
            </items>
            <items code="at1043">
                <items id="text">Slaap/waak toestand</items>
                <items id="description">Slaap/waak toestand, ondersteunt de interpretatie van de 24-uurs bloeddrukmeting.</items>
            </items>
            <items code="at1044">
                <items id="text">Alert en wakker</items>
                <items id="description">Individu is volledig bij bewustzijn.</items>
            </items>
            <items code="at1045">
                <items id="text">Slapend</items>
                <items id="description">Individu is in de natuurlijke slaap.</items>
            </items>
            <items code="at1051">
                <items id="text">Teen</items>
                <items id="description">Een teen van de persoon.</items>
            </items>
            <items code="at1052">
                <items id="text">Beïnvloedende factoren</items>
                <items id="description">Opmerking over en vastleggen van andere incidentele factoren die de bloeddrukmeting zouden kunnen beïnvloeden. Bijvoorbeeld, mate van angst, of 'witte jas syndroom'; pijn of koorts; veranderingen in atmosferische druk etc.</items>
            </items>
            <items code="at1053">
                <items id="text">Intra-arterieel</items>
                <items id="description">Invasieve meting via een druktransducer in de arterielijn.</items>
            </items>
            <items code="at1054">
                <items id="text">Systolische druk formule</items>
                <items id="description">Formule om de systolische druk van de MAP (mean arterial pressure=gemiddelde arteriële druk) te berekenen (als deze data opgeslagen wordt).</items>
            </items>
            <items code="at1055">
                <items id="text">Diastolische druk formule</items>
                <items id="description">Formule om de diastolische druk van de MAP (mean arterial pressure=gemiddelde arteriële druk) te berekenen (als deze data opgeslagen wordt).</items>
            </items>
            <items code="at1056">
                <items id="text">Voetzool</items>
                <items id="description">De voetzool van de persoon.</items>
            </items>
            <items code="at1057">
                <items id="text">Gestructureerde lichaamslocatie van de meting</items>
                <items id="description">Gestructureerde anatomische locatie waar de bloeddruk is gemeten.</items>
            </items>
            <items code="at1058">
                <items id="text">Extensie</items>
                <items id="description">Aanvullende informatie die vereist is om de lokale context vast te leggen of uit te lijnen met andere referentiemodellen/formalismen.</items>
                <items id="comment">Bijvoorbeeld: lokale ziekenhuis of zorginstelling afdelingsinformatie of aanvullende metadata om uit te lijnen met FHIR- of CIMI-equivalenten.</items>
            </items>
            <items code="at1059">
                <items id="text">Klinische interpretatie</items>
                <items id="description">Eén woord, zin of korte beschrijving die de klinische betekenis van de bloeddrukmeting weergeeft.</items>
            </items>
            <items code="deg">
                <items id="text">°</items>
                <items id="description">degree</items>
            </items>
